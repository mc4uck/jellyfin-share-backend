# =============================================================================
# JFShare Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# Jellyfin Configuration
# -----------------------------------------------------------------------------
# Your Jellyfin server URL (use host.docker.internal if running on same machine)
JELLYFIN_URL=http://host.docker.internal:8096

# Jellyfin API Key (generate in Jellyfin Dashboard → API Keys)
JELLYFIN_API_KEY=your-jellyfin-api-key-here

# -----------------------------------------------------------------------------
# Backend Configuration
# -----------------------------------------------------------------------------
# API key for plugin authentication (generate with: openssl rand -hex 32)
BACKEND_API_KEY=your-backend-api-key-here

# Public URL where the share links will be accessible
PUBLIC_BASE_URL=http://localhost:8097

# -----------------------------------------------------------------------------
# Database Configuration (optional, has defaults)
# -----------------------------------------------------------------------------
# Postgres password (generate with: openssl rand -hex 16)
POSTGRES_PASSWORD=jfshare

# =============================================================================
# Quick Setup:
# 1. Copy this file: cp .env.example .env
# 2. Get Jellyfin API key from Dashboard → API Keys → Add
# 3. Generate backend key: openssl rand -hex 32
# 4. Run: make dev-up (development) or make prod-up (production)
# =============================================================================
